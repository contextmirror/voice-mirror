{
  "name": "voice-mirror",
  "private": true,
  "version": "0.12.1",
  "description": "Voice-controlled AI agent overlay for your desktop",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "predev": "taskkill /F /IM voice-mirror-mcp.exe >nul 2>&1 & exit /b 0",
    "dev": "cargo build --manifest-path src-tauri/Cargo.toml --bin voice-mirror-mcp && tauri dev",
    "build": "cargo build --manifest-path src-tauri/Cargo.toml --release --bin voice-mirror-mcp && node -e \"const fs=require('fs');fs.mkdirSync('src-tauri/binaries',{recursive:true});fs.copyFileSync('src-tauri/target/release/voice-mirror-mcp.exe','src-tauri/binaries/voice-mirror-mcp-x86_64-pc-windows-msvc.exe')\" && tauri build",
    "preview": "npx vite build && start \"vite-preview\" /B npx vite preview --port 31420 && timeout /T 2 /NOBREAK >nul && cargo run --manifest-path src-tauri/Cargo.toml --features native-ml,cuda",
    "check": "svelte-check --tsconfig ./jsconfig.json",
    "test": "node --test \"test/**/*.test.cjs\" \"test/**/*.test.mjs\"",
    "test:rust": "cd src-tauri && cargo test",
    "test:all": "npm test && npm run test:rust"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lint": "^6.9.4",
    "@codemirror/merge": "^6.12.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.15",
    "@replit/codemirror-indentation-markers": "^6.5.3",
    "@replit/codemirror-minimap": "^0.5.2",
    "@replit/codemirror-vscode-keymap": "^6.0.2",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.3.1",
    "fuzzysort": "^3.1.0",
    "ghostty-web": "github:contextmirror/ghostty-web",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.0",
    "marked-highlight": "^2.2.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "vite": "^6.0.0"
  },
  "overrides": {
    "rollup": ">=4.59.0"
  }
}
