{
  "$schema": "https://raw.githubusercontent.com/nicobao/tauri/refs/tags/tauri-v2.0.0/crates/tauri-utils/schema.json",
  "productName": "Voice Mirror",
  "version": "0.12.7",
  "identifier": "com.voicemirror.app",
  "build": {
    "beforeDevCommand": "npx vite dev",
    "devUrl": "http://localhost:31420",
    "beforeBuildCommand": "npx vite build",
    "frontendDist": "../dist",
    "features": ["native-ml", "cuda"]
  },
  "app": {
    "windows": [
      {
        "title": "Voice Mirror",
        "width": 900,
        "height": 800,
        "minWidth": 600,
        "minHeight": 500,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' http://127.0.0.1:* http://localhost:* https:; media-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/voice-mirror-mcp"],
    "resources": {
      "../tools/espeak-ng": "espeak-ng"
    },
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "desktopTemplate": null
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "category": "Utility",
    "shortDescription": "Voice-controlled AI agent overlay for your desktop",
    "longDescription": "Voice Mirror is a transparent desktop overlay that lets you control AI agents using your voice. Features speech-to-text, text-to-speech, and integration with multiple AI providers."
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/contextmirror/voice-mirror/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0OUFCQkQ0RTM0NUY3OTkKUldTWjkwWGoxTHVhTkt2VU1wdXh2QW1jT3FHd0wyVEc5Uk1VNWNGKzRJbW5LTlV0VGlDaDZEc0YK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
